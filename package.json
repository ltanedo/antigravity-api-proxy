{
  "name": "antigravity-proxy-tray",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "proxy:install": "npm --prefix proxy-app ci --omit=dev --ignore-scripts",
    "dev": "npm run proxy:install && tauri dev",
    "build": "npm run proxy:install && tauri build",
    "build:debug": "npm run proxy:install && tauri build --debug",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
