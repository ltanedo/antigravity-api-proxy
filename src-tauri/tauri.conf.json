{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antigravity Proxy Tray",
  "version": "0.1.0",
  "identifier": "com.ltanedo.antigravityproxytray",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Antigravity Proxy Tray",
        "width": 420,
        "height": 220,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../proxy-app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
